# Plus Suite GraphQL API credentials.
# Copy this file to .env and fill in real values. .env is gitignored.
#
# npe and prd have separate credentials because each JWT is env-scoped.
# The JWT values should be the raw token — a leading "Bearer " prefix is
# tolerated but not required.

X_API_KEY=your-npe-api-key-here
JWT_TOKEN=your-npe-jwt-here

PRD_API_KEY=your-prd-api-key-here
PRD_JWT_TOKEN=your-prd-jwt-here
